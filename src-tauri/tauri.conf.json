{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Personal Genomics",
  "version": "0.1.0",
  "identifier": "com.morpheus.genomics",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Personal Genomics",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.healthcare-fitness",
    "shortDescription": "Private genomic analysis with Hermes + Morpheus",
    "longDescription": "Upload raw DNA data from 23andMe / AncestryDNA / VCF and generate a private genomic report using a Hermes-style agent backed by Morpheus (Kimi 2.6) with optional TEE-enabled inference for full end-to-end privacy.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
